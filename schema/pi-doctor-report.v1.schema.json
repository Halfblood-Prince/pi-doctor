{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://halfblood-prince.github.io/pi-doctor/schema/pi-doctor-report.v1.schema.json",
  "title": "pi-doctor check report v1",
  "type": "object",
  "required": [
    "metadata",
    "schema_version",
    "overall_status",
    "probe_health",
    "system",
    "config",
    "camera",
    "python",
    "groups",
    "findings"
  ],
  "properties": {
    "metadata": { "$ref": "#/$defs/metadata" },
    "schema_version": { "const": "1.0.0" },
    "overall_status": {
      "enum": ["healthy", "warning", "degraded", "critical"]
    },
    "probe_health": {
      "type": "array",
      "items": { "$ref": "#/$defs/probe_health" }
    },
    "system": { "$ref": "#/$defs/system" },
    "config": { "$ref": "#/$defs/config" },
    "camera": { "$ref": "#/$defs/camera" },
    "python": { "$ref": "#/$defs/python" },
    "groups": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding_group" }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "required": [
        "command",
        "pi_doctor_version",
        "build_revision",
        "target_architecture",
        "supported_os",
        "probe_availability"
      ],
      "properties": {
        "command": { "type": "string" },
        "pi_doctor_version": { "type": "string" },
        "build_revision": { "type": ["string", "null"] },
        "target_architecture": { "type": "string" },
        "supported_os": { "$ref": "#/$defs/supported_os" },
        "probe_availability": { "$ref": "#/$defs/probe_availability" }
      }
    },
    "supported_os": {
      "type": "object",
      "required": ["supported", "family", "version", "codename", "reason"],
      "properties": {
        "supported": { "type": "boolean" },
        "family": { "type": ["string", "null"] },
        "version": { "type": ["string", "null"] },
        "codename": { "type": ["string", "null"] },
        "reason": { "type": ["string", "null"] }
      }
    },
    "probe_availability": {
      "type": "object",
      "required": [
        "total",
        "success",
        "unavailable",
        "permission_denied",
        "command_failed",
        "parse_failed",
        "timed_out"
      ],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "success": { "type": "integer", "minimum": 0 },
        "unavailable": { "type": "integer", "minimum": 0 },
        "permission_denied": { "type": "integer", "minimum": 0 },
        "command_failed": { "type": "integer", "minimum": 0 },
        "parse_failed": { "type": "integer", "minimum": 0 },
        "timed_out": { "type": "integer", "minimum": 0 }
      }
    },
    "probe_health": {
      "type": "object",
      "required": ["name", "outcome", "detail"],
      "properties": {
        "name": { "type": "string" },
        "outcome": {
          "enum": [
            "success",
            "unavailable",
            "permission_denied",
            "command_failed",
            "parse_failed",
            "timed_out"
          ]
        },
        "detail": { "type": ["string", "null"] }
      }
    },
    "system": {
      "type": ["object", "null"],
      "properties": {
        "board_model": { "type": ["string", "null"] },
        "board_revision": { "type": ["string", "null"] },
        "architecture": { "type": ["string", "null"] },
        "distro_name": { "type": ["string", "null"] },
        "distro_version": { "type": ["string", "null"] },
        "distro_codename": { "type": ["string", "null"] },
        "kernel_release": { "type": ["string", "null"] },
        "is_raspberry_pi": { "type": "boolean" }
      }
    },
    "config": {
      "type": ["object", "null"],
      "properties": {
        "source_path": { "type": ["string", "null"] },
        "using_firmware_path": { "type": "boolean" },
        "legacy_path_present": { "type": "boolean" },
        "diagnostics_count": { "type": "integer", "minimum": 0 },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/config_entry" }
        }
      }
    },
    "config_entry": {
      "type": "object",
      "required": ["line_number", "kind", "raw", "section", "key", "value", "comment"],
      "properties": {
        "line_number": { "type": "integer", "minimum": 1 },
        "kind": { "enum": ["blank", "comment", "section", "setting", "malformed"] },
        "raw": { "type": "string" },
        "section": { "type": ["string", "null"] },
        "key": { "type": ["string", "null"] },
        "value": { "type": ["string", "null"] },
        "comment": { "type": ["string", "null"] }
      }
    },
    "camera": {
      "type": ["object", "null"],
      "properties": {
        "tool_used": { "type": ["string", "null"] },
        "rpicam_hello_present": { "type": "boolean" },
        "libcamera_hello_present": { "type": "boolean" },
        "video_devices": { "type": "array", "items": { "type": "string" } },
        "cameras": {
          "type": "array",
          "items": { "$ref": "#/$defs/camera_device" }
        }
      }
    },
    "camera_device": {
      "type": "object",
      "required": ["index", "name", "mode_hint"],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "name": { "type": "string" },
        "mode_hint": { "type": ["string", "null"] }
      }
    },
    "python": {
      "type": ["object", "null"],
      "properties": {
        "version": { "type": ["string", "null"] },
        "executable": { "type": ["string", "null"] },
        "in_virtualenv": { "type": "boolean" },
        "externally_managed": { "type": "boolean" },
        "detected_packages": { "type": "array", "items": { "type": "string" } }
      }
    },
    "finding_group": {
      "type": "object",
      "required": ["domain", "findings"],
      "properties": {
        "domain": {
          "enum": ["system", "power", "thermal", "config", "gpio", "camera", "python"]
        },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/finding" }
        }
      }
    },
    "finding": {
      "type": "object",
      "required": [
        "id",
        "severity",
        "impact",
        "title",
        "summary",
        "evidence",
        "suggested_actions"
      ],
      "properties": {
        "id": { "type": "string" },
        "severity": { "enum": ["info", "warning", "error"] },
        "impact": { "enum": ["info", "warning", "degraded", "critical"] },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "suggested_actions": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
